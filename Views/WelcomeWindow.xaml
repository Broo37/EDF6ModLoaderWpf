<Window x:Class="EDF6ModLoaderWpf.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="🛡️ Welcome to EDF Mod Manager"
        Height="460" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ui:WindowHelper.UseModernWindowStyle="True"
        AutomationProperties.AutomationId="WelcomeWindow"
        AutomationProperties.Name="EDF Mod Manager Welcome Window">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🛡️ Welcome to EDF Mod Manager!"
                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center"/>

        <!-- Subtitle -->
        <TextBlock Grid.Row="2" Text="Which game do you want to set up first?"
                   FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>

        <!-- Game selection radio buttons -->
        <RadioButton x:Name="Edf41Radio" Grid.Row="4" GroupName="GameSelect"
                     Margin="0,0,0,8" Padding="8,6"
                     AutomationProperties.AutomationId="Edf41RadioButton"
                     AutomationProperties.Name="Earth Defense Force 4.1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔵" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Earth Defense Force 4.1: The Shadow of New Despair"
                           FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="Edf5Radio" Grid.Row="5" GroupName="GameSelect"
                     Margin="0,0,0,8" Padding="8,6"
                     AutomationProperties.AutomationId="Edf5RadioButton"
                     AutomationProperties.Name="Earth Defense Force 5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🟢" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Earth Defense Force 5"
                           FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="Edf6Radio" Grid.Row="6" GroupName="GameSelect"
                     IsChecked="True" Margin="0,0,0,8" Padding="8,6"
                     AutomationProperties.AutomationId="Edf6RadioButton"
                     AutomationProperties.Name="Earth Defense Force 6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔴" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Earth Defense Force 6"
                           FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </RadioButton>

        <!-- Tip -->
        <TextBlock Grid.Row="8" HorizontalAlignment="Center"
                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" TextAlignment="Center"
                   Text="💡 You can configure the other games later in Settings!"/>

        <!-- Get Started button -->
        <Button Grid.Row="10" Content="🚀 Get Started!"
                HorizontalAlignment="Center" Padding="32,10"
                FontSize="16" FontWeight="SemiBold"
                Style="{StaticResource AccentButtonStyle}"
                Click="GetStarted_Click"
                AutomationProperties.AutomationId="GetStartedButton"
                AutomationProperties.Name="Get Started"/>
    </Grid>
</Window>
