<Window x:Class="EDF6ModLoaderWpf.Views.ImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="📥 Import Preview"
        Height="580" Width="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ui:WindowHelper.UseModernWindowStyle="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📥 Import Preview" FontSize="22" FontWeight="SemiBold"/>

        <Border Grid.Row="2" Padding="12" CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel>
                <TextBlock FontWeight="SemiBold">
                    <Run Text="Source: "/><Run Text="{Binding Preview.SourceDisplayName}"/>
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <Run Text="Mod Name: "/><Run Text="{Binding Preview.ProposedModName}"/>
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <Run Text="Files: "/><Run Text="{Binding Preview.ImportedFileCount}"/>
                </TextBlock>
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run Text="Destination: "/><Run Text="{Binding Preview.DestinationFolderPath}"/>
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Metadata will be created during import"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Preview.HasMetadata}" Value="True">
                                    <Setter Property="Text" Value="Metadata included in source"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Preview.DetectedGameVersion}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="gameVersion: "/><Run Text="{Binding Preview.DetectedGameVersion}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Import Options" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <RadioButton IsChecked="{Binding ImportAsCopySelected}" Margin="0,0,0,6">
                <TextBlock Text="Import as new copy (recommended)"/>
            </RadioButton>
            <RadioButton IsChecked="{Binding ReplaceExistingSelected}"
                         Visibility="{Binding CanReplaceExisting, Converter={StaticResource BoolToVis}}">
                <TextBlock>
                    <Run Text="Replace existing folder: "/>
                    <Run Text="{Binding Preview.ReplaceTargetFolderName}" FontWeight="SemiBold"/>
                </TextBlock>
            </RadioButton>
        </StackPanel>

        <StackPanel Grid.Row="6"
                    Visibility="{Binding HasDuplicateCandidates, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Possible Duplicates" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <ItemsControl ItemsSource="{Binding Preview.DuplicateCandidates}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock TextWrapping="Wrap">
                            <Run Text="• "/><Run Text="{Binding}"/>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Grid.Row="8"
                    Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Warnings" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"
                       Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}"/>
            <Border Padding="12" CornerRadius="6"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180">
                    <ItemsControl ItemsSource="{Binding Preview.Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,4" TextWrapping="Wrap">
                                    <Run Text="• "/><Run Text="{Binding}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Import" Width="110" Style="{StaticResource AccentButtonStyle}" Click="Import_Click"/>
        </StackPanel>
    </Grid>
</Window>