<Window x:Class="EDF6ModLoaderWpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="⚙️ EDF Mod Manager — Settings"
        Height="560" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ui:WindowHelper.UseModernWindowStyle="True"
        AutomationProperties.AutomationId="SettingsWindow"
        AutomationProperties.Name="EDF Mod Manager Settings">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Title -->
            <RowDefinition Height="16"/>     <!-- 1: spacing -->
            <RowDefinition Height="*"/>      <!-- 2: TabControl -->
            <RowDefinition Height="16"/>     <!-- 3: spacing -->
            <RowDefinition Height="Auto"/>   <!-- 4: Appearance / font -->
            <RowDefinition Height="8"/>      <!-- 5: spacing -->
            <RowDefinition Height="Auto"/>   <!-- 6: Validation -->
            <RowDefinition Height="8"/>      <!-- 7: spacing -->
            <RowDefinition Height="Auto"/>   <!-- 8: Error -->
            <RowDefinition Height="12"/>     <!-- 9: spacing -->
            <RowDefinition Height="Auto"/>   <!-- 10: Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="⚙️ EDF Mod Manager — Settings"
                   FontSize="22" FontWeight="SemiBold"/>

        <!-- Tabbed game configs -->
        <TabControl Grid.Row="2"
                    ItemsSource="{Binding GameProfiles}"
                    SelectedItem="{Binding SelectedProfile}"
                    AutomationProperties.AutomationId="GameProfilesTabControl"
                    AutomationProperties.Name="Game Profiles">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <!-- Color dot per game -->
                        <TextBlock VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🔴"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GameId}" Value="EDF41">
                                            <Setter Property="Text" Value="🔵"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding GameId}" Value="EDF5">
                                            <Setter Property="Text" Value="🟢"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ShortName}" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <StackPanel Margin="8,12,8,0">
                        <!-- Game Directory -->
                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                            <Run Text="Game Directory (contains "/>
                            <Run Text="{Binding ExecutableName, Mode=OneWay}"/>
                            <Run Text=")"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding GameRootPath, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.AutomationId="GameRootPathTextBox"
                                     AutomationProperties.Name="Game Directory"/>
                            <Button Grid.Column="1" Content="📁 Browse" Margin="8,0,0,0"
                                    Command="{Binding DataContext.BrowseGameRootCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    AutomationProperties.AutomationId="BrowseGameRootButton"
                                    AutomationProperties.Name="Browse Game Directory"/>
                        </Grid>

                        <!-- Mods Library Directory -->
                        <TextBlock Text="Mods Library Directory" FontWeight="SemiBold"
                                   Margin="0,16,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ModLibraryPath, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.AutomationId="ModsLibraryPathTextBox"
                                     AutomationProperties.Name="Mods Library Directory"/>
                            <Button Grid.Column="1" Content="📁 Browse" Margin="8,0,0,0"
                                    Command="{Binding DataContext.BrowseModsLibraryCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    AutomationProperties.AutomationId="BrowseModsLibraryButton"
                                    AutomationProperties.Name="Browse Mods Library"/>
                        </Grid>

                        <StackPanel Margin="0,12,0,0">
                            <Button Content="✨ Auto Detect Common Install"
                                    HorizontalAlignment="Left"
                                    Command="{Binding DataContext.AutoDetectSelectedGameCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    AutomationProperties.AutomationId="AutoDetectGameButton"
                                    AutomationProperties.Name="Auto Detect Game Install"/>
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="Searches common Steam library folders and suggests a mods library path when one is missing."/>
                        </StackPanel>

                        <!-- Configuration status indicator -->
                        <TextBlock Margin="0,12,0,0" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⚠️ Not configured"/>
                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                            <Setter Property="Text" Value="✅ Configured and ready"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- Appearance: Font selector -->
        <StackPanel Grid.Row="4" Margin="0,0,0,0">
            <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Font Family" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableFonts}"
                          SelectedItem="{Binding SelectedFontFamily}"
                          MaxDropDownHeight="300"
                          AutomationProperties.AutomationId="FontFamilyComboBox"
                          AutomationProperties.Name="Font Family">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="13"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </StackPanel>

        <!-- Validation message -->
        <TextBlock Grid.Row="6" Text="{Binding ValidationMessage}"
                   Foreground="{DynamicResource TextMutedBrush}"
                   TextWrapping="Wrap"
                   FontSize="12"/>

        <!-- Error message -->
        <TextBlock Grid.Row="8" Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" FontSize="12"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="🗑️ Clear Config" Margin="0,0,8,0"
                    Command="{Binding ClearGameConfigCommand}"
                    AutomationProperties.AutomationId="ClearConfigButton"
                    AutomationProperties.Name="Clear Configuration"/>
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" IsCancel="True"
                    Click="Cancel_Click"
                    AutomationProperties.AutomationId="CancelSettingsButton"
                    AutomationProperties.Name="Cancel Settings"/>
            <Button Content="💾 Save" Width="120" Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SaveCommand}"
                    AutomationProperties.AutomationId="SaveSettingsButton"
                    AutomationProperties.Name="Save Settings"/>
        </StackPanel>
    </Grid>
</Window>
